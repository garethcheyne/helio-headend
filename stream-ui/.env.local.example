# Helio Headend stream-ui — service endpoints
# Copy to .env.local and adjust if the container IPs change.
#
# The Next.js app runs on the nginx host (192.168.0.122) and reaches the
# other containers over the LAN via these server-side calls.

# TVHeadend API (channel grid, tuner status). HTSP is :9982.
TVHEADEND_URL=http://192.168.0.120:9981

# Optional TVHeadend basic-auth credentials (leave blank when running --noacl).
TVHEADEND_USER=
TVHEADEND_PASS=

# Packager container (HLS segmenter).
PACKAGER_URL=http://192.168.0.121

# nginx HLS origin (master playlist + per-channel index.m3u8).
# On-box you can use http://localhost:8080 instead.
HLS_URL=http://192.168.0.122:8080

# HLS port the dashboard UI uses when building stream URLs from window.location
# (whatever domain the browser is on). Empty → same origin as the dashboard.
# Build-time value (NEXT_PUBLIC_*), so changing it needs a rebuild.
NEXT_PUBLIC_HLS_PORT=8080

# Public-facing HLS origin for the server-rendered combined playlist
# (/api/playlist.m3u8). Use your public/mDNS domain that maps to nginx :8080 so
# the internal LAN IP is never embedded. Empty → falls back to HLS_URL.
PUBLIC_HLS_URL=http://weinfoed.local:8080

# Comma-separated host list the dashboard health-checks.
# Format: id|name|url  (trim/extend freely — drives the Service Status panel)
HEALTH_HOSTS=101|TVHeadend|http://192.168.0.120:9981,102|Packager|http://192.168.0.121,103|nginx HLS|http://192.168.0.122:8080

# --- Internet Streams + admin ---------------------------------------------

# SQLite database file (created automatically). Holds the internet streams.
DATABASE_PATH=./data/headend.db

# Simple single-operator admin login (migratable to DB users later).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Secret used to sign the session cookie — set to a long random string.
AUTH_SECRET=change-me-to-a-long-random-secret

# Stream validation process.
# How long a validity result is trusted before a read triggers a re-check (minutes).
STREAM_CHECK_TTL_MIN=15
# Optional background re-validation interval in minutes (0 = disabled, rely on
# on-read TTL / manual checks / external cron hitting POST /api/streams/check).
STREAM_CHECK_INTERVAL_MIN=0
# Optional shared token. Allows an unauthenticated cron to call the check route,
# and lets LAN TVs / IPTV apps fetch the combined playlist (which embeds internal
# LAN URLs and is otherwise admin-only):
#   curl -X POST "http://localhost:3000/api/streams/check?token=$STREAM_CHECK_TOKEN"
#   http://<host>:3000/api/playlist.m3u8?token=$STREAM_CHECK_TOKEN
STREAM_CHECK_TOKEN=
