# =============================================================================
# stream-ui — PRODUCTION config (internet-facing, runs on the .122 container)
# Copy to /etc/helio/stream-ui.env and fill in the TODOs. Keep this file 0600.
# NOTE: NEXT_PUBLIC_* values are baked in at BUILD time — re-run the build
#       (deploy.sh sources this file) after changing them.
# =============================================================================

NODE_ENV=production

# --- Upstream LAN services (server-side only — never exposed publicly) -------
TVHEADEND_URL=http://192.168.0.120:9981
PACKAGER_URL=http://192.168.0.121
HLS_URL=http://192.168.0.122:8080
HEALTH_HOSTS=101|TVHeadend|http://192.168.0.120:9981,102|Packager|http://192.168.0.121,103|nginx HLS|http://192.168.0.122:8080

# --- Public origin -----------------------------------------------------------
# nginx serves /hls/ on the SAME HTTPS origin as the dashboard, so the browser
# builds stream URLs as https://<your-domain>/hls/... (no port, no mixed content).
# Leave NEXT_PUBLIC_HLS_PORT EMPTY for same-origin.
NEXT_PUBLIC_HLS_PORT=
# Used by the server-rendered combined playlist (/api/playlist.m3u8):
PUBLIC_HLS_URL=https://tv.example.com          # TODO: your real domain

# --- Admin auth (CHANGE THESE) ----------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=__set_a_strong_password__       # TODO
# Generate: openssl rand -base64 48
AUTH_SECRET=__generated_secret__               # TODO
# Generate: openssl rand -hex 24  (used for cron + LAN-TV playlist access)
STREAM_CHECK_TOKEN=__generated_token__         # TODO

# --- Database (persistent path, backed up) -----------------------------------
DATABASE_PATH=/var/lib/helio/stream-ui/headend.db

# --- Stream validation -------------------------------------------------------
STREAM_CHECK_TTL_MIN=15
# Re-validate every internet stream in the background every N minutes (0 = off):
STREAM_CHECK_INTERVAL_MIN=30
